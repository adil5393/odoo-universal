<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_picking_form_multi_add_inherit" model="ir.ui.view">
        <field name="name">stock.picking.form.multi.add.inherit</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='button_validate']" position="before">
                <button name="action_open_multi_add"
                        type="object"
                        string="Add Multiple Products"
                        class="btn-secondary"
                        invisible="state in ('done', 'cancel') or picking_type_code != 'internal'"/>
            </xpath>
        </field>
    </record>

</odoo>
