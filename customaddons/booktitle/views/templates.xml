<odoo>
    <data>
      <template id="pdf_quote_inherit" inherit_id="sale.report_saleorder_document">
          <xpath expr="//table[@class='table table-sm o_main_table table-borderless mt-4']//thead//tr//th[@name='th_description']" position="after">
                      <th>Name</th>
          </xpath>
          <xpath expr="//table[@class='table table-sm o_main_table table-borderless mt-4']//tbody//td[@name='td_name']" position="after">
              <td>
                  <t t-esc="line.booktitle.name if line.booktitle else 'Unknown'"/>
              </td>
          </xpath>
      </template>

      <template id = 'pdf_with_payment_inherit' inherit_id='account.report_invoice_document'>
          <xpath expr="//t[@t-call='web.external_layout']//div[@class='mt-5 clearfix']//div[@class='page mb-4']//table[@class='table table-sm o_main_table table-borderless']//thead//tr//th[@name='th_description']" position="after">
              <th class="text-start">Name</th>
          </xpath>

          <xpath expr = "//t[@t-call='web.external_layout']//div[@class='mt-5 clearfix']//div[@class='page mb-4']//table//tbody[@class='invoice_tbody']//t[@t-foreach='lines']//tr//t//td[@name = 'account_invoice_line_name']" position="after">
            <td>
              <t t-esc="line.booktitle or ''"/>
            </td>
          </xpath>
          <xpath expr = "//div[@id='right-elements']//table" position="inside">
          <t t-if="not o.sudo().invoice_payments_widget or not o.sudo().invoice_payments_widget['content']">
            <tr class="border-black fw-bold">
              <td> Amount Due</td>
              <td class="text-end">
                <span t-field="o.amount_residual"/>
              </td>
            </tr>
          </t>
          </xpath>
      </template>
    </data>
</odoo>
