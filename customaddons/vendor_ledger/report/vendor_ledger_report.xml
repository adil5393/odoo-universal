<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_vendor_ledger" model="ir.actions.report">
        <field name="name">Vendor Ledger</field>
        <field name="model">vendor.ledger.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">vendor_ledger.report_vendor_ledger_template</field>
        <field name="report_file">vendor_ledger.report_vendor_ledger_template</field>
        <field name="print_report_name">'Vendor Ledger - %s' % object.vendor_id.name</field>
    </record>

    <template id="report_vendor_ledger_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-set="data" t-value="doc._get_ledger_data()"/>
                <t t-set="o" t-value="data['vendor']"/>
                <t t-set="cur" t-value="data['currency']"/>
                <div class="page" style="font-family:Arial,sans-serif;">

                    <!-- Header -->
                    <div style="border-bottom:3px solid #2c3e50; margin-bottom:18px; padding-bottom:14px;">
                        <table style="width:100%; border-collapse:collapse;">
                            <tr>
                                <td style="vertical-align:top;">
                                    <div style="font-size:22px; font-weight:bold; color:#2c3e50; letter-spacing:1px;">VENDOR LEDGER</div>
                                    <div style="font-size:14px; font-weight:bold; color:#333; margin-top:4px;"><t t-esc="o.name"/></div>
                                    <t t-if="o.street">
                                        <div style="font-size:10px; color:#555; margin-top:2px;"><t t-esc="o.street"/></div>
                                    </t>
                                    <t t-if="o.city or o.country_id">
                                        <div style="font-size:10px; color:#555;">
                                            <t t-esc="(o.city or '') + (', ' + o.country_id.name if o.country_id else '')"/>
                                        </div>
                                    </t>
                                    <t t-if="o.phone">
                                        <div style="font-size:10px; color:#555;">Tel: <t t-esc="o.phone"/></div>
                                    </t>
                                    <t t-if="o.vat">
                                        <div style="font-size:10px; color:#555;">Tax ID: <t t-esc="o.vat"/></div>
                                    </t>
                                </td>
                                <td style="vertical-align:top; text-align:right; width:210px;">
                                    <div style="background:#f0f4f8; border:1px solid #d0d8e4; padding:10px 14px; border-radius:4px; display:inline-block; text-align:left;">
                                        <div style="font-size:9px; color:#888; text-transform:uppercase; letter-spacing:0.5px;">Period</div>
                                        <div style="font-size:11px; font-weight:bold; color:#2c3e50; margin-bottom:6px;">
                                            <t t-esc="data['date_from']"/> to <t t-esc="data['date_to']"/>
                                        </div>
                                        <div style="font-size:9px; color:#888; text-transform:uppercase; letter-spacing:0.5px;">Currency</div>
                                        <div style="font-size:11px; font-weight:bold; color:#2c3e50;">
                                            <t t-esc="cur.name"/>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        </table>
                    </div>

                    <!-- Ledger Table -->
                    <table style="width:100%; border-collapse:collapse; font-size:10px;">
                        <thead>
                            <tr style="background-color:#2c3e50; color:#ffffff;">
                                <th style="padding:8px 7px; text-align:left; width:75px; font-weight:600;">Date</th>
                                <th style="padding:8px 7px; text-align:left; width:110px; font-weight:600;">Reference</th>
                                <th style="padding:8px 7px; text-align:left; font-weight:600;">Memo / Cheque No.</th>
                                <th style="padding:8px 7px; text-align:left; width:62px; font-weight:600;">Type</th>
                                <th style="padding:8px 7px; text-align:right; width:88px; font-weight:600;">Purchase</th>
                                <th style="padding:8px 7px; text-align:right; width:88px; font-weight:600;">Payment</th>
                                <th style="padding:8px 7px; text-align:right; width:88px; font-weight:600;">Refund</th>
                                <th style="padding:8px 7px; text-align:right; width:88px; font-weight:600;">Balance</th>
                            </tr>
                        </thead>
                        <tbody>

                            <!-- Opening Balance -->
                            <tr style="background-color:#dce8f8;">
                                <td style="padding:6px 7px; border-bottom:1px solid #c5d8ee; font-weight:bold;">
                                    <t t-esc="data['date_from']"/>
                                </td>
                                <td colspan="6" style="padding:6px 7px; border-bottom:1px solid #c5d8ee; font-weight:bold; font-style:italic; color:#2c3e50;">
                                    Opening Balance
                                </td>
                                <td style="padding:6px 7px; border-bottom:1px solid #c5d8ee; font-weight:bold; text-align:right;">
                                    <t t-esc="'{:,.2f}'.format(data['opening_balance'])"/>
                                </td>
                            </tr>

                            <!-- Transaction Lines -->
                            <t t-foreach="data['lines']" t-as="line">
                                <tr t-attf-style="background-color:{{ '#ffffff' if line_index % 2 == 0 else '#f7f9fc' }};">
                                    <td style="padding:5px 7px; border-bottom:1px solid #ebebeb; color:#444;">
                                        <t t-esc="line['date']"/>
                                    </td>
                                    <td style="padding:5px 7px; border-bottom:1px solid #ebebeb; color:#333; font-size:9px;">
                                        <t t-esc="line['reference']"/>
                                    </td>
                                    <td style="padding:5px 7px; border-bottom:1px solid #ebebeb; color:#555;">
                                        <t t-esc="line['memo']"/>
                                    </td>
                                    <td style="padding:5px 7px; border-bottom:1px solid #ebebeb;">
                                        <span t-attf-style="
                                            display:inline-block;
                                            padding:1px 6px;
                                            border-radius:3px;
                                            font-size:9px;
                                            font-weight:bold;
                                            background-color:{{ '#fff3cd' if line['type']=='Purchase' else ('#d4edda' if line['type']=='Payment' else '#f8d7da') }};
                                            color:{{ '#856404' if line['type']=='Purchase' else ('#155724' if line['type']=='Payment' else '#721c24') }};">
                                            <t t-esc="line['type']"/>
                                        </span>
                                    </td>
                                    <td style="padding:5px 7px; text-align:right; border-bottom:1px solid #ebebeb; color:#c0392b;">
                                        <t t-if="line['purchase']"><t t-esc="'{:,.2f}'.format(line['purchase'])"/></t>
                                    </td>
                                    <td style="padding:5px 7px; text-align:right; border-bottom:1px solid #ebebeb; color:#27ae60;">
                                        <t t-if="line['payment']"><t t-esc="'{:,.2f}'.format(line['payment'])"/></t>
                                    </td>
                                    <td style="padding:5px 7px; text-align:right; border-bottom:1px solid #ebebeb; color:#8e44ad;">
                                        <t t-if="line['refund']"><t t-esc="'{:,.2f}'.format(line['refund'])"/></t>
                                    </td>
                                    <td style="padding:5px 7px; text-align:right; border-bottom:1px solid #ebebeb; font-weight:600; color:#2c3e50;">
                                        <t t-esc="'{:,.2f}'.format(line['balance'])"/>
                                    </td>
                                </tr>
                            </t>

                            <!-- Totals Row -->
                            <tr style="background-color:#2c3e50; color:#ffffff; font-weight:bold;">
                                <td colspan="4" style="padding:8px 7px; font-size:11px; letter-spacing:0.5px;">TOTAL</td>
                                <td style="padding:8px 7px; text-align:right;"><t t-esc="'{:,.2f}'.format(data['total_purchases'])"/></td>
                                <td style="padding:8px 7px; text-align:right;"><t t-esc="'{:,.2f}'.format(data['total_payments'])"/></td>
                                <td style="padding:8px 7px; text-align:right;"><t t-esc="'{:,.2f}'.format(data['total_refunds'])"/></td>
                                <td style="padding:8px 7px; text-align:right;"></td>
                            </tr>

                            <!-- Closing Balance -->
                            <tr style="background-color:#dce8f8; font-weight:bold;">
                                <td colspan="7" style="padding:8px 7px; font-size:11px; color:#2c3e50; font-style:italic;">Closing Balance</td>
                                <td style="padding:8px 7px; text-align:right; font-size:12px; color:#2c3e50;">
                                    <t t-esc="'{:,.2f}'.format(data['closing_balance'])"/>
                                </td>
                            </tr>

                        </tbody>
                    </table>

                    <!-- Summary Box -->
                    <div style="margin-top:22px; text-align:right;">
                        <table style="border-collapse:collapse; font-size:10px; display:inline-table; min-width:260px;">
                            <tr>
                                <td style="padding:6px 12px; border:1px solid #ddd; background:#f7f9fc; color:#555;">Opening Balance</td>
                                <td style="padding:6px 12px; border:1px solid #ddd; text-align:right; font-weight:600;">
                                    <t t-esc="'{:,.2f}'.format(data['opening_balance'])"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding:6px 12px; border:1px solid #ddd; background:#fff3cd; color:#856404;">Total Purchases</td>
                                <td style="padding:6px 12px; border:1px solid #ddd; text-align:right; font-weight:600; color:#c0392b;">
                                    <t t-esc="'{:,.2f}'.format(data['total_purchases'])"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding:6px 12px; border:1px solid #ddd; background:#d4edda; color:#155724;">Total Payments</td>
                                <td style="padding:6px 12px; border:1px solid #ddd; text-align:right; font-weight:600; color:#27ae60;">
                                    (<t t-esc="'{:,.2f}'.format(data['total_payments'])"/>)
                                </td>
                            </tr>
                            <tr>
                                <td style="padding:6px 12px; border:1px solid #ddd; background:#f8d7da; color:#721c24;">Total Refunds</td>
                                <td style="padding:6px 12px; border:1px solid #ddd; text-align:right; font-weight:600; color:#8e44ad;">
                                    (<t t-esc="'{:,.2f}'.format(data['total_refunds'])"/>)
                                </td>
                            </tr>
                            <tr style="background-color:#2c3e50; color:#ffffff;">
                                <td style="padding:8px 12px; font-weight:bold; font-size:11px; border:1px solid #2c3e50;">Net Balance Due</td>
                                <td style="padding:8px 12px; text-align:right; font-weight:bold; font-size:12px; border:1px solid #2c3e50;">
                                    <t t-esc="cur.name"/> <t t-esc="'{:,.2f}'.format(data['closing_balance'])"/>
                                </td>
                            </tr>
                        </table>
                    </div>

                </div>
            </t>
        </t>
    </template>

</odoo>
